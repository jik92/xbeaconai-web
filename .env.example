# Required by `bun run start`. Generate a long random value and never commit it.
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters

API_HOST=127.0.0.1
API_PORT=8787
# Comma-separated browser origins allowed to call /api routes.
ALLOWED_ORIGINS=http://app.xbeaconai.com,http://api.xbeaconai.com
# Browser API origin embedded by Vite during a production build.
VITE_API_BASE_URL=http://api.xbeaconai.com
ALLOW_MOCK_FALLBACK=true
FORCE_MOCK=false

# OpenAI-compatible provider configuration used by the model SDK scripts.
OPENAI_BASE_URL=
OPENAI_KEY=

# Volcengine TOS private staging bucket for Seedance references.
TOS_ACCESS_KEY_ID=
TOS_SECRET_ACCESS_KEY=
TOS_REGION=cn-beijing
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_BUCKET=xbeacon
