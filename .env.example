# Required by `bun run start`. Generate a long random value and never commit it.
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
# Encrypts provider credentials stored in SQLite. Keep this outside the database.
BYOK_ENCRYPTION_KEY=replace-with-a-different-random-secret-at-least-32-characters
# Comma-separated phones can access the system management console.
ADMIN_PHONE=17688743518,13800000000

API_HOST=127.0.0.1
API_PORT=8787
# Comma-separated browser origins allowed to call /api routes.
ALLOWED_ORIGINS=https://app.xbeaconai.com,https://api.xbeaconai.com,http://118.196.101.57:9000
# Browser API origin embedded by Vite during a production build.
VITE_API_BASE_URL=https://api.xbeaconai.com
ALLOW_MOCK_FALLBACK=true
FORCE_MOCK=false

# BullMQ queue. The API process only publishes jobs; `make run-worker` consumes them.
REDIS_URL=redis://127.0.0.1:6379
REDIS_QUEUE_NAME=yaozuo-jobs
WORKER_CONCURRENCY=2

# Douyin downloader: keep headless outside local debugging. Setting this to
# false opens a visible temporary Chromium profile for the current job.
DOUYIN_BROWSER_HEADLESS=true
# Optional local-debug pause after the share page opens (0–300000 ms).
DOUYIN_BROWSER_DEBUG_PAUSE_MS=0
# Wait for the optional Douyin login guidance overlay before attempting close.
DOUYIN_LOGIN_GUIDANCE_WAIT_MS=30000

# OpenAI-compatible provider configuration used by the model SDK scripts.
OPENAI_BASE_URL=
OPENAI_KEY=
VIDEO_ANALYSIS_MODEL=gemini-3.5-flash

# Provider credentials belong in `.env.key`; non-sensitive Provider defaults live in `web/app/config.ts`.

# Volcengine SMS test overrides. The app reuses imported TOS access keys and defaults from `web/app/config.ts`.
# Set only VOLC_SMS_TEST_PHONE to test the configured app defaults; the other fields are optional overrides.
VOLC_SMS_ACCESS_KEY_ID=
VOLC_SMS_SECRET_ACCESS_KEY=
VOLC_SMS_ACCOUNT=
VOLC_SMS_SIGN=
VOLC_SMS_TEMPLATE_ID=
VOLC_SMS_TEST_PHONE=

# AI MediaKit settings for real subtitle erasure and media tools. Its API Key belongs in `.env.key`.
MEDIAKIT_BASE_URL=https://mediakit.cn-beijing.volces.com
MEDIAKIT_POLL_INTERVAL_MS=5000
MEDIAKIT_POLL_TIMEOUT_MS=1800000
