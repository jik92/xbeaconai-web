# Required by `bun run start`. Generate a long random value and never commit it.
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters

API_HOST=127.0.0.1
API_PORT=8787
# Comma-separated browser origins allowed to call /api routes.
ALLOWED_ORIGINS=https://app.xbeaconai.com,https://api.xbeaconai.com,http://118.196.101.57:9000
# Browser API origin embedded by Vite during a production build.
VITE_API_BASE_URL=https://api.xbeaconai.com
ALLOW_MOCK_FALLBACK=true
FORCE_MOCK=false

# BullMQ queue. The API process only publishes jobs; `make run-worker` consumes them.
REDIS_URL=redis://127.0.0.1:6379
REDIS_QUEUE_NAME=yaozuo-jobs
WORKER_CONCURRENCY=2

# OpenAI-compatible provider configuration used by the model SDK scripts.
OPENAI_BASE_URL=
OPENAI_KEY=
VIDEO_ANALYSIS_MODEL=gemini-3.5-flash

# Volcengine Doubao Voice (new console API Key authentication).
# API_KEY_ID is inventory metadata only; requests authenticate with API_KEY.
VOLC_SPEECH_API_KEY_ID=
VOLC_SPEECH_API_KEY=
VOLC_SPEECH_BASE_URL=https://openspeech.bytedance.com
VOLC_SPEECH_CLONE_RESOURCE_ID=seed-icl-2.0
VOLC_SPEECH_TTS_RESOURCE_ID=seed-icl-2.0
VOLC_SPEECH_PRESET_TTS_RESOURCE_ID=seed-tts-2.0
VOLC_SPEECH_POLL_INTERVAL_MS=2000
VOLC_SPEECH_POLL_TIMEOUT_MS=180000

# Volcengine TOS private staging bucket for Seedance references.
TOS_ACCESS_KEY_ID=
TOS_SECRET_ACCESS_KEY=
TOS_REGION=cn-beijing
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_BUCKET=xbeacon

# AI MediaKit API Key for real subtitle erasure and media tools.
MEDIAKIT_API_KEY=
MEDIAKIT_BASE_URL=https://mediakit.cn-beijing.volces.com
MEDIAKIT_POLL_INTERVAL_MS=5000
MEDIAKIT_POLL_TIMEOUT_MS=1800000
