{
  "name": "@studio/ai-creation",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:all": "bun run --parallel dev:api dev",
    "dev:api": "bun --hot server/index.ts",
    "dev:worker": "bun --watch worker/index.ts",
    "api": "bun server/index.ts",
    "worker": "bun worker/index.ts",
    "start": "NODE_ENV=production bun server/index.ts",
    "api:spec": "bun scripts/export-openapi.ts",
    "api:generate": "bun scripts/generate-api-client.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "drizzle-kit check",
    "db:studio": "drizzle-kit studio",
    "test:models": "bun scripts/test-model-sdks.ts",
    "test:seedance:multimodal": "bun scripts/test-seedance-multimodal.ts",
    "test:video-analysis": "bun scripts/test-video-analysis.ts",
    "test:tos": "bun scripts/test-tos-sdk.ts",
    "test:ffmpeg": "bun scripts/test-ffmpeg-sdk.ts",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "bun test tests/unit",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.5.1",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.18",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.6",
    "@volcengine/tos-sdk": "^2.9.1",
    "bullmq": "^5.80.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.4.4",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@hey-api/openapi-ts": "^0.99.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^4.3.3",
    "typescript": "6.0.3",
    "vite": "^8.1.5"
  }
}
